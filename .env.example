# Telegram Bot Token from @BotFather
TELEGRAM_TOKEN=your_token_here

# Group chat IDs (comma-separated, negative numbers)
# Use @userinfobot or forward a message to get chat ID
ALLOWED_CHAT_IDS=-100xxxxxxxxxx

# User IDs allowed in DM (comma-separated, !!!first one = owner/admin!!!)
# Use @userinfobot to get your user ID
ALLOWED_DM_USERS=your_user_id

# Path to ffmpeg executable
FFMPEG_PATH=C:\path\to\ffmpeg.exe